{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "dotenv -e .env.development -- astro dev",
    "prepod": "dotenv -e .env.production -- astro dev",
    "preprod": "dotenv -e .env.production -- astro dev",
    "build": "dotenv -e .env.production -- astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check:conflicts": "node ./scripts/check-conflicts.mjs",
    "check": "npm run check:conflicts && astro check",
    "lint": "npm run check:conflicts && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/tailwind": "^6.0.2",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "astro": "^5.18.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.548.0",
    "motion": "^11.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.25.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.25.1",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1"
  }
}
