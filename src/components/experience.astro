---
import { experienceDataEn } from "../data/experienceDataEn";
import { experienceDataEs } from "../data/experienceDataEs";
import { experienceHighlightWords as wordsHighlights } from "../data/experienceHighlightWords";
---

<section class="px-5 md:px-10 lg:px-20 py-8">
  <div class="max-w-5xl mx-auto">
    <!-- Title -->
    <div class="mb-6 space-y-2">
      <div class="flex items-center gap-4">
        <h2 
          class="text-xl md:text-2xl font-bold tracking-tight bg-gradient-to-r from-white to-gray-400 bg-clip-text text-transparent"
          data-i18n="experience.title"
        >
          Experiencia
        </h2>
        <img src="/icons/work.svg" alt="" class="w-8 h-8 opacity-80" />
      </div>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-500 to-blue-700 rounded-full"></div>
    </div>

    <!-- Timeline -->
    <div class="relative pl-8 md:pl-12">
      <!-- Vertical line -->
      <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-gradient-to-b from-blue-500 via-blue-600 to-transparent"></div>

      <div class="space-y-6 lang-en">
        {
          experienceDataEn.map((exp) => (
            <div class="relative group">
              <!-- Timeline dot -->
              <div class="absolute -left-[2.40rem] md:-left-[3.40rem] top-2 w-4 h-4 bg-blue-500 rounded-full border-4 border-gray-900 group-hover:scale-125 group-hover:bg-blue-400 transition-transform duration-300 shadow-lg shadow-blue-500/50">
              </div>

              <!-- Content card -->
              <div class="relative">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
                
                <div class="relative bg-gray-900/80 border border-gray-800 rounded-xl p-3 md:p-5 hover:border-gray-700 transition-colors duration-200">
                  <!-- Header -->
                  <div class="mb-3 space-y-1">
                    <h3 class="text-lg md:text-xl font-semibold text-blue-400 group-hover:text-blue-300 transition-colors duration-300">
                      {exp.title}
                    </h3>
                    <div class="flex items-center gap-2 text-gray-400">
                      <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      <span class="text-xs md:text-sm">{exp.period}</span>
                    </div>
                  </div>
                  <!-- Description -->
                  <ul class="space-y-1">
                    {exp.description.map((item: string) => (
                      <li class="flex gap-2 text-gray-300 leading-relaxed text-sm">
                        <span class="text-blue-500 mt-1.5 flex-shrink-0">▹</span>
                        <span class="flex-1">
                          {item.split(/\s+/).map((word: string) => {
                            const cleanWord = word.replace(/[.,:;!?(){}[\]]/g, "");
                            return (
                              <span
                                class={`${
                                  wordsHighlights.includes(cleanWord)
                                    ? "text-blue-400 font-semibold hover:text-blue-300 transition-colors duration-200"
                                    : ""
                                }`}
                              >
                                {word}{" "}
                              </span>
                            );
                          })}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="space-y-6 lang-es">
        {
          experienceDataEs.map((exp) => (
            <div class="relative group">
              <!-- Timeline dot -->
              <div class="absolute -left-[2.40rem] md:-left-[3.40rem] top-2 w-4 h-4 bg-blue-500 rounded-full border-4 border-gray-900 group-hover:scale-125 group-hover:bg-blue-400 transition-transform duration-300 shadow-lg shadow-blue-500/50">
              </div>

              <!-- Content card -->
              <div class="relative">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-blue-600 to-purple-600 rounded-xl opacity-0 group-hover:opacity-20 transition-opacity duration-300"></div>
                
                <div class="relative bg-gray-900/80 border border-gray-800 rounded-xl p-3 md:p-5 hover:border-gray-700 transition-colors duration-200">
                  <!-- Header -->
                  <div class="mb-3 space-y-1">
                    <h3 class="text-lg md:text-xl font-semibold text-blue-400 group-hover:text-blue-300 transition-colors duration-300">
                      {exp.title}
                    </h3>
                    <div class="flex items-center gap-2 text-gray-400">
                      <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      <span class="text-xs md:text-sm">{exp.period}</span>
                    </div>
                  </div>
                  <!-- Description -->
                  <ul class="space-y-1">
                    {exp.description.map((item: string) => (
                      <li class="flex gap-2 text-gray-300 leading-relaxed text-sm">
                        <span class="text-blue-500 mt-1.5 flex-shrink-0">▹</span>
                        <span class="flex-1">
                          {item.split(/\s+/).map((word: string) => {
                            const cleanWord = word.replace(/[.,:;!?(){}[\]]/g, "");
                            return (
                              <span
                                class={`${
                                  wordsHighlights.includes(cleanWord)
                                    ? "text-blue-400 font-semibold hover:text-blue-300 transition-colors duration-200"
                                    : ""
                                }`}
                              >
                                {word}{" "}
                              </span>
                            );
                          })}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
