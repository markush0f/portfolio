---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  themeColor?: string;
  pageName?: string;
}

const {
  title = "Markus Abramian Medina | Portfolio",
  description = "Portfolio de Markus Abramian Medina, desarrollador full stack especializado en frontend, backend e integracion de IA.",
  themeColor = "#0f0f0f",
  pageName = "default",
} = Astro.props as Props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <title>{title}</title>
  </head>
  <body class="scroll-smooth" data-page={pageName}>
    <div
      id="page-transition-overlay"
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-[999] opacity-0"
    >
      <div class="page-transition-surface"></div>
      <div class="page-transition-line"></div>
    </div>
    <slot />
  </body>
</html>
