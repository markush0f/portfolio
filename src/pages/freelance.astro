---
import { FreelanceAboutGsap } from "../features/freelance/components/FreelanceAboutGsap";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Freelancer Portfolio"
  description="Pagina freelance de Markus Abramian Medina, enfocada en una propuesta honesta para proyectos web y de software."
  themeColor="#0f0f0f"
  pageName="freelance"
>
  <div
    class="freelance-shell min-h-screen bg-[var(--bg-primary)] text-[var(--text-primary)]"
  >
    <FreelanceAboutGsap client:load />
  </div>
</Layout>

<style>
  .freelance-shell {
    background: #0b0d10;
    color: var(--text-primary);
  }
</style>
